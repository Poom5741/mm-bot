# =====================================================================
# MGW/USDC Market-Maker Bot — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# =====================================================================

# --- Network ---
NETWORK=testnet  # testnet | mainnet

# --- Trading ---
TARGET_PAIR=PURR/USDC  # Use PURR/USDC for testnet validation; flip to MGW/USDC when listed
ORDER_SIZE_USDC=10
TICK_OFFSET=2
QUOTE_INTERVAL_SEC=30

# --- Risk Caps ---
MAX_INVENTORY_USDC=100
MAX_CAPITAL_USDC=200
MIN_SPREAD_TICKS=1
MAX_SPREAD_TICKS=10
KILL_SWITCH_VOL_THRESHOLD=0.05

# --- Logging ---
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# --- Secrets (NEVER commit real values) ---
# WARNING: The values below are PLACEHOLDERS ONLY.
# Replace with your actual bot wallet agent private key and Telegram credentials.
# Committing real keys here will expose your funds.
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY_HERE
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_OWNER_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
